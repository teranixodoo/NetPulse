# Zkopíruj tento soubor do .env a doplň skutečné hodnoty
# cp .env.example .env

# PostgreSQL heslo
POSTGRES_PASSWORD=zvol_silne_heslo

# Fernet šifrovací klíč pro credentials v DB
# Vygeneruj: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# JWT secret pro přihlašování
# Vygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# URL backendu pro Next.js proxy (frontend-react kontejner → FastAPI na hostu)
# Výchozí: http://host.docker.internal:8000 (Docker Compose 2.x + Linux)
# Pokud proxy nefunguje, nastav IP serveru kde běží backend, např.:
# BACKEND_URL=http://10.221.0.65:8000
BACKEND_URL=
